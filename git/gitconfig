[core]
        excludesfile = ~/.gitignore_global

[init]
        defaultBranch = main

[user]
        name = Craig Rivers
        email = craig@orbital.tech

[alias]
        discard = checkout --
        unstage = reset --
        uncommit = reset --soft HEAD~

        branches = branch -a
        stashes = stash list
        remotes = remote -v
        tags = tag

[apply]
        whitespace = warn

[color]
        ui = auto

[diff]
        colorMoved = default
        renames = copies
        compactionHeuristic = true
        indentHeuristic = on

[merge]
        conflictstyle = diff3
        log = true

[help]
        autocorrect = 1

[push]
        default = simple

[pull]
        rebase = true

[rebase]
        updateRefs = true

[filter "lfs"]
        clean = git-lfs clean -- %f
        smudge = git-lfs smudge -- %f
        process = git-lfs filter-process
        required = true
