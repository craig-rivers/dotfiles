#!/usr/bin/env bash

input=$(cat)
model=$(echo "$input" | jq -r '.model.display_name // "Unknown"' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')
branch=$(git branch --show-current 2>/dev/null)
project=$(basename "$PWD")

# Context window usage % from Claude Code's input (actual token usage)
context_pct=$(echo "$input" | jq -r '.context_window.used_percentage // empty' 2>/dev/null)

# Get active block data from ccusage
block_data=$(ccusage blocks --active --json 2>/dev/null | jq '.blocks[0]' 2>/dev/null)

if [ -z "$block_data" ] || [ "$block_data" = "null" ]; then
    printf "%s | %s/%s" "$model" "$project" "$branch"
    [ -n "$context_pct" ] && printf "\ncontext: %d%%" "$context_pct"
    exit 0
fi

# Block usage % using cost-weighted tokens to match the Claude dashboard.
block_budget=111
cost_usd=$(echo "$block_data" | jq -r '.costUSD // 0')
block_pct=$(echo "$cost_usd $block_budget" | awk '{printf "%d", ($1 / $2) * 100}')

# Remaining time from projection
remaining_mins=$(echo "$block_data" | jq -r '.projection.remainingMinutes // 0')

# Format time remaining
if [ "$remaining_mins" -lt 60 ]; then
    time_left="${remaining_mins}m"
elif [ "$remaining_mins" -lt 1440 ]; then
    hours=$((remaining_mins / 60))
    mins=$((remaining_mins % 60))
    time_left="${hours}h${mins}m"
else
    days=$((remaining_mins / 1440))
    hours=$(((remaining_mins % 1440) / 60))
    time_left="${days}d${hours}h"
fi

# Build output
printf "%s | %s/%s\n" "$model" "$project" "$branch"
stats=""
[ -n "$context_pct" ] && stats="context: ${context_pct}%"
stats="${stats:+$stats | }block: ${block_pct}% used | ${time_left} left"
printf "%s" "$stats"
